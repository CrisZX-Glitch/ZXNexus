-- =============================================
-- ESP COMPLETO - Murderer / Hero / Sheriff / Innocent
-- =============================================

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer

local ESP = {}

-- Configurações separadas por role
local settings = {
    Enabled = true,
    Murderer = { Name = true, Tracer = true, Highlight = true },
    Sheriff = { Name = true, Tracer = true, Highlight = true },
    Hero = { Name = true, Tracer = true, Highlight = true },
    Innocent = { Name = true, Tracer = true, Highlight = true },
}

local drawings = {}      -- Tracers
local highlights = {}    -- Highlights
local billboards = {}    -- Names

-- ==================== DETECÇÃO DE ROLE ====================
local function getPlayerRole(player)
    if not player or not player.Character then return "Innocent" end
    
    local char = player.Character
    local bp = player:FindFirstChild("Backpack")
    
    if char then
        if char:FindFirstChild("Knife") then return "Murderer" end
        if char:FindFirstChild("Gun") then return "Sheriff" end
    end
    if bp then
        if bp:FindFirstChild("Knife") then return "Murderer" end
        if bp:FindFirstChild("Gun") then return "Sheriff" end
    end
    return "Innocent"
end

-- ==================== TRACERS ====================
local function createTracer(player)
    if drawings[player] then return end
    local tracer = Drawing.new("Line")
    tracer.Thickness = 2
    tracer.Transparency = 1
    tracer.Visible = false
    drawings[player] = tracer
end

local function updateTracers()
    for player, tracer in pairs(drawings) do
        if player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local role = getPlayerRole(player)
            local shouldShow = settings.Enabled and settings[role] and settings[role].Tracer
            
            local root = player.Character.HumanoidRootPart
            local camera = Workspace.CurrentCamera
            local screenPos, onScreen = camera:WorldToViewportPoint(root.Position)
            
            if onScreen and shouldShow then
                local color = role == "Murderer" and Color3.fromRGB(255, 0, 0)
                         or role == "Sheriff" and Color3.fromRGB(0, 100, 255)
                         or role == "Hero" and Color3.fromRGB(255, 255, 0)
                         or Color3.fromRGB(0, 255, 100)
                
                tracer.Color = color
                tracer.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                tracer.To = Vector2.new(screenPos.X, screenPos.Y)
                tracer.Visible = true
            else
                tracer.Visible = false
            end
        else
            if drawings[player] then
                drawings[player]:Remove()
                drawings[player] = nil
            end
        end
    end
end

-- ==================== HIGHLIGHTS ====================
local function updateHighlights()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local role = getPlayerRole(player)
            local shouldShow = settings.Enabled and settings[role] and settings[role].Highlight
            
            local highlight = player.Character:FindFirstChild("ESP_Highlight")
            
            if shouldShow then
                if not highlight then
                    highlight = Instance.new("Highlight")
                    highlight.Name = "ESP_Highlight"
                    highlight.Adornee = player.Character
                    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    highlight.FillTransparency = 0.65
                    highlight.OutlineTransparency = 0.3
                    highlight.Parent = player.Character
                end
                
                if role == "Murderer" then
                    highlight.FillColor = Color3.fromRGB(255, 60, 60)
                elseif role == "Sheriff" then
                    highlight.FillColor = Color3.fromRGB(60, 120, 255)
                elseif role == "Hero" then
                    highlight.FillColor = Color3.fromRGB(255, 255, 80)
                else
                    highlight.FillColor = Color3.fromRGB(80, 255, 120)
                end
            else
                if highlight then highlight:Destroy() end
            end
        end
    end
end

-- ==================== CONTROLE ====================
function ESP.Toggle(state)
    settings.Enabled = state
end

function ESP.ToggleRole(role, name, tracer, highlight)
    if settings[role] then
        settings[role].Name = name
        settings[role].Tracer = tracer
        settings[role].Highlight = highlight
    end
end

function ESP.Start()
    -- Limpa antigo
    for _, v in pairs(drawings) do if v then v:Remove() end end
    drawings = {}
    
    -- Inicia loops
    RunService.RenderStepped:Connect(updateTracers)
    RunService.Heartbeat:Connect(updateHighlights)
    
    -- Cria tracers para jogadores atuais
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            createTracer(plr)
        end
    end
    
    -- Novo jogador
    Players.PlayerAdded:Connect(function(plr)
        if plr ~= LocalPlayer then
            createTracer(plr)
        end
    end)
    
    print("👁️ ESP Completo Iniciado (Murderer / Sheriff / Hero / Innocent)")
end

return ESP
