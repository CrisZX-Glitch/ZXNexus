-- =============================================
-- FLING COM ESCOLHA DE PLAYER
-- =============================================

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer

local Fling = {}
local isFlinging = false
local flingConnection = nil

local function getHRP(player)
    if player and player.Character then
        return player.Character:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

local function flingPlayer(target)
    if not target or not target.Character then return false end
    
    local targetRoot = getHRP(target)
    if not targetRoot then return false end
    
    -- Fling forte
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(99999, 99999, 99999)
    bv.Velocity = targetRoot.CFrame.LookVector * 280 + Vector3.new(0, 120, 0)
    bv.Parent = targetRoot
    
    -- Spin
    local angular = Instance.new("BodyAngularVelocity")
    angular.MaxTorque = Vector3.new(99999, 99999, 99999)
    angular.AngularVelocity = Vector3.new(0, 150, 0)
    angular.Parent = targetRoot
    
    game.Debris:AddItem(bv, 2.2)
    game.Debris:AddItem(angular, 2.2)
    
    print("💥 Fling aplicado em: " .. target.Name)
    return true
end

-- ==================== FLING POR NOME ====================
function Fling.ToPlayer(name)
    local target = Players:FindFirstChild(name)
    if target then
        flingPlayer(target)
    else
        print("❌ Jogador não encontrado: " .. name)
    end
end

-- ==================== FLING RÁPIDO ====================
function Fling.Murderer()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local char = plr.Character
            local bp = plr:FindFirstChild("Backpack")
            if (char and char:FindFirstChild("Knife")) or (bp and bp:FindFirstChild("Knife")) then
                flingPlayer(plr)
                return
            end
        end
    end
    print("❌ Nenhum Murderer encontrado")
end

function Fling.Sheriff()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local char = plr.Character
            local bp = plr:FindFirstChild("Backpack")
            if (char and char:FindFirstChild("Gun")) or (bp and bp:FindFirstChild("Gun")) then
                flingPlayer(plr)
                return
            end
        end
    end
    print("❌ Nenhum Sheriff encontrado")
end

function Fling.Nearest()
    local myRoot = getHRP(LocalPlayer)
    if not myRoot then return end
    
    local nearest, shortest = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local root = getHRP(plr)
            if root then
                local dist = (myRoot.Position - root.Position).Magnitude
                if dist < shortest then
                    shortest = dist
                    nearest = plr
                end
            end
        end
    end
    if nearest then
        flingPlayer(nearest)
    end
end

-- ==================== FLING CONTÍNUO ====================
function Fling.ToggleContinuous(state, targetType)
    isFlinging = state
    
    if state then
        print("💥 Fling Contínuo Ativado | Alvo: " .. targetType)
        
        flingConnection = RunService.Heartbeat:Connect(function()
            if not isFlinging then return end
            
            local target = nil
            if targetType == "Murderer" then
                target = findMurderer()  -- função interna
            elseif targetType == "Sheriff" then
                target = findSheriff()
            elseif targetType == "Nearest" then
                -- usa Nearest acima
                Fling.Nearest()
                task.wait(1.5)
                return
            end
            
            if target then
                flingPlayer(target)
                task.wait(1.8)
            end
        end)
        
    else
        if flingConnection then
            flingConnection:Disconnect()
            flingConnection = nil
        end
        print("💥 Fling Contínuo Desativado")
    end
end

-- Lista de players para UI
function Fling.GetPlayerList()
    local list = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            table.insert(list, plr.Name)
        end
    end
    return list
end

return Fling
